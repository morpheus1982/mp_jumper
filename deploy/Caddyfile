{
        # 全局禁用自动 HTTPS（仅对需要的地方）
        auto_https disable_redirects
}

# HTTP 测试端口
:60080 {
        root * /opt/docker/mp_jumper/html
        file_server browse

        log {
                output stdout
                format console
        }
}

# HTTPS 生产端口 - 自动 SSL (阿里云 DNS-01 验证)
www.512028.xyz {
        root * /opt/docker/mp_jumper/html
        file_server browse
        encode gzip

        # 自动 SSL 证书 - 阿里云 DNS 验证
        tls {
                dns alidns {
                        access_key_id {$ALICLOUD_ACCESS_KEY}
                        access_key_secret {$ALICLOUD_SECRET_KEY}
                }
        }

        log {
                output stdout
                format console
        }
}
