<view class="container">
  <!-- 隐私授权弹窗 -->
  <view class="privacy-mask" wx:if="{{showPrivacy}}">
    <view class="privacy-popup">
      <view class="privacy-title">用户隐私保护提示</view>
      <view class="privacy-desc">
        感谢您使用文章收藏小程序。我们需要获取您的剪贴板权限，以便快速粘贴文章链接。
      </view>
      <view class="privacy-btns">
        <button class="btn-disagree" bindtap="onPrivacyDisagree">拒绝</button>
        <button class="btn-agree" id="agree-btn" open-type="agreePrivacyAuthorization" bindtap="onPrivacyAgree">同意</button>
      </view>
    </view>
  </view>

  <!-- 输入状态 -->
  <view wx:if="{{state === 'input'}}" class="state-container">
    <view class="input-card">
      <view class="input-header">
        <text class="input-label">文章链接</text>
        <button class="paste-btn-small" bindtap="onPasteClick">粘贴</button>
      </view>
      <textarea
        class="url-input"
        placeholder="点击粘贴按钮，或长按此处粘贴"
        value="{{inputUrl}}"
        bindinput="onInputChange"
        auto-height
        maxlength="2000"
        focus="{{inputFocus}}"
        show-confirm-bar="{{false}}"
        adjust-position="{{true}}"
      ></textarea>
    </view>
    <button class="add-btn" bindtap="onFetchTitle">获取标题</button>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{state === 'loading'}}" class="state-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">获取文章信息...</text>
  </view>

  <!-- 预览状态 -->
  <view wx:if="{{state === 'preview'}}" class="state-container">
    <button class="paste-btn" bindtap="onReInput">重输</button>
    <view class="article-card">
      <text class="article-icon">📄</text>
      <text class="article-title">{{articleTitle}}</text>
      <view class="url-display-card">
        <text class="url-display-text">{{articleUrl}}</text>
      </view>
    </view>
    <button class="add-btn" bindtap="onAdd">添加</button>
  </view>

  <!-- 已存在状态 -->
  <view wx:if="{{state === 'exists'}}" class="state-container">
    <button class="paste-btn" bindtap="onReInput">重输</button>
    <view class="warning-text">⚠️ 该文章已添加过</view>
    <view class="article-card">
      <text class="article-icon">📄</text>
      <text class="article-title">{{articleTitle}}</text>
      <view class="url-display-card">
        <text class="url-display-text">{{articleUrl}}</text>
      </view>
    </view>
    <button class="add-btn" bindtap="onReInput">输入新链接</button>
  </view>

  <!-- 结果状态 -->
  <view wx:if="{{state === 'result'}}" class="state-container">
    <view class="result-icon">✅</view>
    <text class="result-text">文章已插入</text>
    <text class="result-id" wx:if="{{result.id}}">ID: {{result.id}}</text>
    <button class="add-btn" bindtap="onContinue">继续添加</button>
  </view>

  <!-- 错误状态 -->
  <view wx:if="{{state === 'error'}}" class="state-container">
    <button class="paste-btn" bindtap="onContinue">重试</button>
    <view class="error-icon">❌</view>
    <text class="error-text">{{errorMessage}}</text>
  </view>
</view>
